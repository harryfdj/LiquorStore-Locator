<script>
document.addEventListener('click', function (e) {
  var el = e.target.closest('[data-millerdrive]');
  if (!el) return; // si el clic no fue en tu contenedor, no hace nada

  e.preventDefault();

  // Cambia solo el dominio, mantiene todo lo demás (slug, hash del popup, etc.)
  var newUrl = window.location.href.replace('://megawineandspirits.com', '://millerdrive.megawineandspirits.com');

  window.location.href = newUrl;
});
</script>


