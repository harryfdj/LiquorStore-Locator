					<!-- 1) Carga el cliente de Google Identity Services -->
<script src="https://accounts.google.com/gsi/client" async defer></script>

<!-- 2) Contenedor donde se inyectará el botón -->
<div id="mi-gsi-button"></div>

<script>
  // 3) Callback que recibe el ID Token de Google y hace la redirección
  function handleCredentialResponse(response) {
    // Aquí rediriges a tu URI con el token como parámetro
    window.location.href = 
      'https://megawineandspirits.com/?token=' 
      + encodeURIComponent(response.credential);
  }

  // 4) Cuando Elementor abra el popup, inicializamos y renderizamos el botón
  jQuery(window).on('elementor/popup/show', function(event, popup) {
    var cont = document.getElementById('mi-gsi-button');
    // Solo si existe y todavía no está renderizado
    if (cont && cont.childElementCount === 0 && window.google && google.accounts && google.accounts.id) {
      google.accounts.id.initialize({
        client_id: '339814332875-pe6jsgdngc5l49h9gppvbf338m2r7e91.apps.googleusercontent.com',
        callback: handleCredentialResponse,
        ux_mode: 'popup'
      });
      google.accounts.id.renderButton(
        cont,
        {
          type: 'standard',
          shape: 'pill',
          theme: 'filled_black',
          text: 'signin_with',
          size: 'medium',
          logo_alignment: 'left'
        }
      );
    }
  });
</script>
